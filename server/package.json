{
  "name": "shotlab-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backend for ShotLab — bilingual prompt-engineering app for visual creators",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.mjs",
    "setup": "prisma generate && prisma db push && node prisma/seed.mjs",
    "test": "node test/api.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
