{
  "info": {
    "name": "ShotLab API",
    "description": "Backend for ShotLab — bilingual prompt-engineering app for visual creators. Cookie-session auth: run 'Auth > Signup' or 'Login' first; the session cookie is stored automatically and sent on subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "email", "value": "you@studio.com" },
    { "key": "password", "value": "secret123" },
    { "key": "promptId", "value": "l1" },
    { "key": "templateId", "value": "" },
    { "key": "fileId", "value": "" },
    { "key": "resetToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "GET /health", "request": { "method": "GET", "url": "{{baseUrl}}/health" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Creator\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" },
            "url": "{{baseUrl}}/auth/signup"
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        { "name": "POST /auth/guest", "request": { "method": "POST", "url": "{{baseUrl}}/auth/guest" } },
        { "name": "GET /auth/me", "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" } },
        { "name": "POST /auth/logout", "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" } },
        {
          "name": "POST /auth/reset/request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" },
            "url": "{{baseUrl}}/auth/reset/request"
          }
        },
        {
          "name": "POST /auth/reset/confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"newsecret123\"\n}" },
            "url": "{{baseUrl}}/auth/reset/confirm"
          }
        },
        {
          "name": "POST /auth/change-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"newsecret123\"\n}" },
            "url": "{{baseUrl}}/auth/change-password"
          }
        },
        {
          "name": "PATCH /auth/profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Updated\"\n}" },
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        { "name": "GET /auth/google (open in browser)", "request": { "method": "GET", "url": "{{baseUrl}}/auth/google" } }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "POST /ai/generate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"inputType\": \"text\",\n  \"idea\": \"Luxury perfume ad for Saudi National Day\",\n  \"attributes\": { \"style\": \"Cinematic\", \"lighting\": \"Golden hour\", \"aspect\": \"4:5\" },\n  \"lang\": \"en\"\n}" },
            "url": "{{baseUrl}}/ai/generate"
          }
        },
        {
          "name": "POST /ai/generate (image ref)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"inputType\": \"image\",\n  \"fileId\": \"{{fileId}}\",\n  \"attributes\": { \"style\": \"Product\" },\n  \"lang\": \"en\"\n}" },
            "url": "{{baseUrl}}/ai/generate"
          }
        },
        {
          "name": "POST /ai/score",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"You are a product photographer. Create a hero shot on marble, 85mm, golden hour, 4:5.\",\n  \"lang\": \"en\"\n}" },
            "url": "{{baseUrl}}/ai/score"
          }
        },
        {
          "name": "POST /ai/improve",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"prompt\": \"make a nice coffee picture\",\n  \"lang\": \"en\"\n}" },
            "url": "{{baseUrl}}/ai/improve"
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "POST /uploads",
          "request": {
            "method": "POST",
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": [] }] },
            "url": "{{baseUrl}}/uploads"
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        { "name": "GET /templates", "request": { "method": "GET", "url": "{{baseUrl}}/templates" } },
        {
          "name": "POST /templates",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"My hero shot\",\n  \"body\": \"You are a photographer... [Product]\",\n  \"source\": \"studio\",\n  \"cats\": [\"mine\"]\n}" },
            "url": "{{baseUrl}}/templates"
          }
        },
        {
          "name": "PATCH /templates/:id",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Renamed hero\"\n}" },
            "url": "{{baseUrl}}/templates/{{templateId}}"
          }
        },
        { "name": "DELETE /templates/:id", "request": { "method": "DELETE", "url": "{{baseUrl}}/templates/{{templateId}}" } }
      ]
    },
    {
      "name": "Saved",
      "item": [
        { "name": "GET /saved", "request": { "method": "GET", "url": "{{baseUrl}}/saved" } },
        {
          "name": "POST /saved",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Saved prompt\",\n  \"body\": \"body text\",\n  \"source\": \"studio\"\n}" },
            "url": "{{baseUrl}}/saved"
          }
        },
        { "name": "DELETE /saved/:id", "request": { "method": "DELETE", "url": "{{baseUrl}}/saved/{{templateId}}" } }
      ]
    },
    {
      "name": "Favorites",
      "item": [
        { "name": "GET /favorites", "request": { "method": "GET", "url": "{{baseUrl}}/favorites" } },
        { "name": "POST /favorites/:promptId", "request": { "method": "POST", "url": "{{baseUrl}}/favorites/{{promptId}}" } },
        { "name": "DELETE /favorites/:promptId", "request": { "method": "DELETE", "url": "{{baseUrl}}/favorites/{{promptId}}" } }
      ]
    },
    {
      "name": "History",
      "item": [
        { "name": "GET /history", "request": { "method": "GET", "url": "{{baseUrl}}/history" } },
        {
          "name": "POST /history",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"type\": \"platform\",\n  \"label\": \"Midjourney\"\n}" },
            "url": "{{baseUrl}}/history"
          }
        },
        { "name": "DELETE /history (clear)", "request": { "method": "DELETE", "url": "{{baseUrl}}/history" } }
      ]
    },
    {
      "name": "Library",
      "item": [
        { "name": "GET /library", "request": { "method": "GET", "url": "{{baseUrl}}/library" } },
        { "name": "GET /library?category=product-ads", "request": { "method": "GET", "url": "{{baseUrl}}/library?category=product-ads" } },
        { "name": "GET /library?q=perfume", "request": { "method": "GET", "url": "{{baseUrl}}/library?q=perfume" } },
        { "name": "GET /library?mine=true", "request": { "method": "GET", "url": "{{baseUrl}}/library?mine=true" } },
        { "name": "GET /library?fav=true", "request": { "method": "GET", "url": "{{baseUrl}}/library?fav=true" } }
      ]
    }
  ]
}
