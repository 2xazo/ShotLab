# ---------------------------------------------------------------------------
# ShotLab backend — environment
# Copy to .env and fill in. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# HTTP
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed browser origins for CORS (the frontend).
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500,null

# ---------------------------------------------------------------------------
# Database (PostgreSQL). ShotLab keeps its tables in a dedicated `shotlab`
# schema so it can share a Postgres instance with other apps safely.
#   - DATABASE_URL : used by the app at runtime (pooled connection is fine).
#   - DIRECT_URL   : a direct (non-pooled) connection used only for migrations.
# For hosted Supabase/Neon, paste your own connection string(s).
# For the bundled docker-compose Postgres use:
#   postgresql://shotlab:shotlab@localhost:5432/shotlab?schema=shotlab
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=shotlab
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=shotlab

# ---------------------------------------------------------------------------
# Auth / sessions (JWT in httpOnly cookies)
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=7d
# Set true in production (HTTPS) so cookies are marked Secure + SameSite=None.
COOKIE_SECURE=false
# Cookie domain (leave blank for host-only cookies in dev).
COOKIE_DOMAIN=

# ---------------------------------------------------------------------------
# LLM provider — swappable. LLM_PROVIDER = openai | anthropic
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# ---------------------------------------------------------------------------
# Email (password reset) — Nodemailer. In development, if SMTP_HOST is empty
# the reset link is logged to the server console instead of emailed.
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ShotLab <no-reply@shotlab.app>"
# Where the reset link should point (your frontend), token appended as ?token=
APP_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Google Identity Services (optional — the "Continue with Google" button).
# Use a Google OAuth 2.0 Web Client ID. This public ID initializes the browser
# SDK and is also used by the backend to verify each ID token's audience.
# No client secret or redirect URI is needed for this credential flow.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# ---------------------------------------------------------------------------
# Uploads. STORAGE_DRIVER = local | s3
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
# Only needed when STORAGE_DRIVER=s3 (S3-compatible: AWS S3, R2, Supabase, MinIO)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
